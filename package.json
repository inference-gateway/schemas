{
  "name": "schemas",
  "version": "0.0.0-semantically-released",
  "description": "Shared schemas (OpenAPI, A2A, MCP) for the Inference Gateway ecosystem",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/inference-gateway/schemas.git"
  },
  "engines": {
    "bun": ">=1.3.13"
  },
  "scripts": {
    "lint": "markdownlint '**/*.md'",
    "lint:fix": "markdownlint '**/*.md' --fix",
    "format": "prettier --write '**/*.yaml'",
    "openapi:format": "prettier --write openapi.yaml",
    "openapi:lint": "bunx @stoplight/spectral-cli lint --verbose openapi.yaml",
    "check-reachable": "bun scripts/check-reachable.js",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run --no-ci"
  },
  "dependencies": {
    "js-yaml": "^5.1.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^7.0.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^11.0.0",
    "@semantic-release/github": "^12.0.8",
    "conventional-changelog-conventionalcommits": "^10.2.0",
    "markdownlint-cli": "^0.49.0",
    "prettier": "3.9.6",
    "semantic-release": "^25.0.5"
  }
}
